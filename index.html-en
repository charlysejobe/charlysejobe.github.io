    <!-- Projects Section -->
    <section class="section section-alt" id="projects">
        <div class="container">
            <div class="section-header">
                <span class="section-tag"><i class="fas fa-code"></i> Projects & Experience</span>
                <h2 class="section-title">My IT Experience</h2>
                <p class="section-subtitle">A selection of academic and professional projects showing my skills in cybersecurity and software development.</p>
            </div>
            
            <div class="projects-grid">
                <!-- Projet Malware -->
                <div class="project-card featured" data-reveal data-modal="modal-malware" style="cursor:pointer">
                    <div class="project-icon"><i class="fas fa-virus"></i></div>
                    <div class="project-badge">Featured</div>
                    <div class="project-date"><i class="far fa-calendar"></i> Jan 2026 — Jun 2026</div>
                    <h3 class="project-title">Windows Malware Classification via Graph Analysis (CFG)</h3>
                    <p class="project-description">
                        Classified <strong>3,850 Windows malware samples</strong> using static analysis of Control Flow Graphs (CFG). Used Graph Neural Networks to bypass code obfuscation techniques.
                    </p>
                    <div class="project-details">
                        <div class="detail-item"><i class="fa-solid fa-atom"></i><span>Research project</span></div>
                        <div class="detail-item"><i class="fas fa-bullseye"></i><span>Built an obfuscation-resistant pipeline</span></div>
                        <div class="detail-item"><i class="fas fa-brain"></i><span>Implemented a GIN (Graph Isomorphism Network)</span></div>
                        <div class="detail-item"><i class="fas fa-tachometer-alt"></i><span>Optimized with Python multiprocessing</span></div>
                    </div>
                    <div class="project-tags">
                        <span class="tag tag-cyber">Python</span>
                        <span class="tag tag-cyber">PyTorch Geometric</span>
                        <span class="tag tag-cyber">angr</span>
                        <span class="tag tag-cyber">Reverse Engineering</span>
                        <span class="tag tag-cyber">GNN</span>
                    </div>
                </div>

                <!-- Projet SwipeFund -->
                <div class="project-card" data-reveal data-modal="modal-swipefund" style="cursor:pointer">
                    <div class="project-icon"><i class="fas fa-globe"></i></div>
                    <div class="project-date"><i class="far fa-calendar"></i> Mar 2026 — Jun 2026</div>
                    <h3 class="project-title">SwipeFund — Web App Platform</h3>
                    <p class="project-description">
                        Developed a full web app from scratch in a 4-person team. We used vanilla technologies. I built the search engine, the user interfaces, and the technical documentation.
                    </p>
                    <div class="project-details">
                        <div class="detail-item"><i class="fas fa-search"></i><span>Dynamic search with tags and filters</span></div>
                        <div class="detail-item"><i class="fas fa-universal-access"></i><span>WCAG Accessibility & W3C validation</span></div>
                        <div class="detail-item"><i class="fas fa-map"></i><span>Leaflet API for interactive maps</span></div>
                    </div>
                    <div class="project-tags">
                        <span class="tag tag-dev">HTML5/CSS3</span>
                        <span class="tag tag-dev">Vanilla JS</span>
                        <span class="tag tag-dev">REST API</span>
                        <span class="tag tag-dev">LocalStorage</span>
                        <span class="tag tag-dev">GitLab</span>
                    </div>
                    <a href="https://github.com/charlysejobe/swipe-fund-web-app" target="_blank" rel="noopener" class="project-link"><i class="fab fa-github"></i> View on GitHub</a>
                </div>

                <!-- Projet IoT -->
                <div class="project-card" data-reveal data-modal="modal-iot" style="cursor:pointer">
                    <div class="project-icon"><i class="fas fa-microchip"></i></div>
                    <div class="project-date"><i class="far fa-calendar"></i> Sep 2024 — Jan 2025</div>
                    <h3 class="project-title">IoT & Accessibility Semester Project</h3>
                    <p class="project-description">
                        Designed and built an assistive device for visually impaired people. Processed real-time hardware data. Added haptic and audio feedback for better spatial awareness.
                    </p>
                    <div class="project-details">
                        <div class="detail-item"><i class="fas fa-hand-sparkles"></i><span>Real-time haptic and audio feedback</span></div>
                        <div class="detail-item"><i class="fas fa-camera"></i><span>Environment analysis via Raspberry Pi camera</span></div>
                    </div>
                    <div class="project-tags">
                        <span class="tag tag-iot">Python</span>
                        <span class="tag tag-iot">Raspberry Pi 4</span>
                        <span class="tag tag-iot">Embedded Systems</span>
                        <span class="tag tag-iot">Camera</span>
                        <span class="tag tag-iot">Haptic Sensors</span>
                    </div>
                </div>

                <!-- Projet EGM -->
                <div class="project-card" data-reveal data-modal="modal-egm" style="cursor:pointer">
                    <div class="project-icon"><i class="fas fa-chart-line"></i></div>
                    <div class="project-badge badge-work">Internship</div>
                    <div class="project-date"><i class="far fa-calendar"></i> Jun 2025 — Jul 2025</div>
                    <h3 class="project-title">Data Processing & Automation — EGM</h3>
                    <p class="project-description">
                        Internship at EGM, a sustainable tech company. Created an automated Python pipeline. It analyzes sensor data (eNose, Pixelo) using Pandas and Matplotlib. I also did lab measurements.
                    </p>
                    <div class="project-details">
                        <div class="detail-item"><i class="fas fa-robot"></i><span>Modular data pipeline with Pandas & Matplotlib</span></div>
                        <div class="detail-item"><i class="fas fa-flask"></i><span>Practical lab measurements on sensors</span></div>
                    </div>
                    <div class="project-tags">
                        <span class="tag tag-data">Python</span>
                        <span class="tag tag-data">Pandas</span>
                        <span class="tag tag-data">Matplotlib</span>
                        <span class="tag tag-data">IoT Sensors</span>
                    </div>
                    <a href="https://github.com/charlysejobe/egm_internship" target="_blank" rel="noopener" class="project-link"><i class="fab fa-github"></i> View on GitHub</a>
                </div>
            </div>
        </div>
    </section>

